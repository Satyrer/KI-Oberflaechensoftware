# Copy this file to config/local.properties and fill in local machine values.
# config/local.properties is ignored by Git and must not be committed.

# Complete endpoint wins over host/port/path when set.
ki.endpoint=
ki.provider=ollama

# Alternative endpoint parts, used when ki.endpoint is empty.
ki.host=192.168.178.41
ki.port=11435
ki.path=/api/chat

# Optional credentials and model selection for the local AI service.
ki.apiKey=
ki.model=mistral-rag:latest
ki.timeoutSeconds=300

# Current local AI stack / n8n chat administration.
n8n.host=192.168.178.41
n8n.chatAdmin.port=8088
n8n.chatAdmin.baseUrl=
n8n.chatAdmin.token=

# n8n WebUI import for chats from /home/chat.
# These credentials are used only locally to read/import/delete one selected WebUI chat.
n8n.web.port=5678
n8n.web.baseUrl=
n8n.web.email=
n8n.web.password=
n8n.web.timeoutSeconds=90

# Schreib-AI Workflow. Defaults to n8n.web.baseUrl / n8n.host:5678 when empty.
n8n.schreibAi.baseUrl=
n8n.schreibAi.timeoutSeconds=240

# AI answers through n8n Chat Trigger instead of direct Ollama/Mistral.
# Enable "Make Chat Publicly Available" in the n8n Chat Trigger and paste the Chat URL here.
n8n.chatWebhook.url=
n8n.chatWebhook.authorization=

# Local storage folders. These folders are ignored by Git.
chat.directory=chats
